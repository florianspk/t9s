# Talos Linux multi-node cluster for upgrade testing
# Usage:
#   cd hack/vagrant
#   ./download-iso.sh        # download Talos ISO once
#   vagrant up               # boot VMs (boots from ISO, installs to disk, reboots)
#   ./apply-configs.sh       # apply machine configs + bootstrap
#
# Then test upgrades with:
#   ./t9s --talosconfig talosconfig

TALOS_VERSION = "v1.7.0"

# Node IPs on a host-only network
CP_IP     = "192.168.56.10"
WORKER_IP = "192.168.56.11"

Vagrant.configure("2") do |config|
  # No base box — VMs boot directly from the Talos ISO
  config.vm.box = "hashicorp/bionic64"   # dummy; overridden by ISO boot below
  config.vm.box_download_insecure = true

  # Disable default synced folder (Talos has no guest additions)
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # ── controlplane ──────────────────────────────────────────────────────────
  config.vm.define "controlplane" do |cp|
    cp.vm.hostname = "talos-cp"
    cp.vm.network "private_network", ip: CP_IP

    cp.vm.provider "virtualbox" do |vb|
      vb.name   = "talos-cp"
      vb.memory = 2048
      vb.cpus   = 2

      # Boot from Talos metal ISO (maintenance mode on first boot)
      iso = File.expand_path("talos-amd64.iso", __dir__)
      vb.customize ["storageattach", :id,
        "--storagectl", "IDE Controller",
        "--port", "1", "--device", "0",
        "--type", "dvddrive",
        "--medium", iso]
      vb.customize ["modifyvm", :id, "--boot1", "disk", "--boot2", "dvd"]

      # Disk for Talos installation (8 GB minimum)
      disk = File.expand_path(".vagrant/talos-cp.vmdk", __dir__)
      unless File.exist?(disk)
        vb.customize ["createmedium", "disk", "--filename", disk,
                      "--size", 10240, "--format", "VMDK"]
      end
      vb.customize ["storageattach", :id,
        "--storagectl", "SATA Controller",
        "--port", "0", "--device", "0",
        "--type", "hdd", "--medium", disk]
    end
  end

  # ── worker ────────────────────────────────────────────────────────────────
  config.vm.define "worker" do |wk|
    wk.vm.hostname = "talos-worker"
    wk.vm.network "private_network", ip: WORKER_IP

    wk.vm.provider "virtualbox" do |vb|
      vb.name   = "talos-worker"
      vb.memory = 2048
      vb.cpus   = 2

      iso = File.expand_path("talos-amd64.iso", __dir__)
      vb.customize ["storageattach", :id,
        "--storagectl", "IDE Controller",
        "--port", "1", "--device", "0",
        "--type", "dvddrive",
        "--medium", iso]
      vb.customize ["modifyvm", :id, "--boot1", "disk", "--boot2", "dvd"]

      disk = File.expand_path(".vagrant/talos-worker.vmdk", __dir__)
      unless File.exist?(disk)
        vb.customize ["createmedium", "disk", "--filename", disk,
                      "--size", 10240, "--format", "VMDK"]
      end
      vb.customize ["storageattach", :id,
        "--storagectl", "SATA Controller",
        "--port", "0", "--device", "0",
        "--type", "hdd", "--medium", disk]
    end
  end
end
